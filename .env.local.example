# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this in the browser (no NEXT_PUBLIC_ prefix)
# Used only in API routes for admin writes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get this from: resend.com → API Keys
# Used to send contact form submissions to your inbox
RESEND_API_KEY=re_your_key_here
CONTACT_EMAIL_TO=hello@meridiangroup.com
CONTACT_EMAIL_FROM=noreply@meridiangroup.com
